{
  "manifest_version": 3,
  "name": "LinkedIn Analyzer",
  "description": "Analisa perfis do LinkedIn e sugere melhorias com base no headline e nas experiencias exibidas na pagina.",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.onrender.com/*",
    "https://www.linkedin.com/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*"
      ],
      "js": [
        "content/script.js"
      ]
    }
  ]
}