{
  "name": "extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "manifest:dev": "node scripts/use-manifest.mjs dev",
    "manifest:store": "node scripts/use-manifest.mjs store",
    "assets:store": "node scripts/generate-store-assets.mjs",
    "predev": "npm run manifest:dev",
    "dev": "vite --mode development",
    "build": "npm run build:store",
    "prebuild:dev": "npm run manifest:dev",
    "build:dev": "tsc -b && vite build --mode development",
    "prebuild:store": "npm run manifest:store",
    "build:store": "tsc -b && vite build",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "prepreview": "npm run manifest:store",
    "preview": "vite preview"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.38",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^27.0.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.1"
  }
}
